<?xml version="1.0" encoding="UTF-8"?>
<!--
  Log4j2 日志配置（结构化 JSON 格式）
  - 控制台：彩色可读格式（方便本地开发）
  - 文件：JSON 结构化格式（方便 ELK/Loki 采集解析）
  - 日志中自动携带 traceId（来自 MDC，由 TraceIdFilter 注入）
-->
<Configuration status="WARN" monitorInterval="30">

    <Properties>
        <Property name="LOG_HOME">logs</Property>
        <Property name="FILE_NAME">application</Property>
        <Property name="APP_NAME">resource-platform</Property>
        <!-- 控制台可读格式（包含 traceId）-->
        <Property name="CONSOLE_PATTERN">
            %d{yyyy-MM-dd HH:mm:ss.SSS} %highlight{%-5level}{FATAL=Bright Red, ERROR=Red, WARN=Yellow, INFO=Green, DEBUG=Cyan} [%thread] [%X{traceId}] %logger{36} - %msg%n
        </Property>
    </Properties>

    <Appenders>

        <!-- ==================== 控制台（可读格式）==================== -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${CONSOLE_PATTERN}" disableAnsi="false"/>
        </Console>

        <!-- ==================== JSON 文件（ELK/Loki 采集）==================== -->
        <!-- 全量日志（JSON 格式，便于日志平台解析）-->
        <RollingFile name="JsonFileAll"
                     fileName="${LOG_HOME}/${FILE_NAME}.json"
                     filePattern="${LOG_HOME}/${FILE_NAME}-%d{yyyy-MM-dd}-%i.json.gz">
            <JsonTemplateLayout>
                <!-- 标准字段 -->
                <EventTemplateAdditionalField key="service"    value="${APP_NAME}"/>
                <EventTemplateAdditionalField key="env"        value="$${spring:spring.profiles.active:-dev}"/>
                <!-- 从 MDC 注入 traceId -->
            </JsonTemplateLayout>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="100MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30">
                <Delete basePath="${LOG_HOME}" maxDepth="1">
                    <IfFileName glob="${FILE_NAME}-*.json.gz"/>
                    <IfLastModified age="30d"/>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!-- ERROR 日志单独文件（便于告警监控）-->
        <RollingFile name="JsonFileError"
                     fileName="${LOG_HOME}/${FILE_NAME}-error.json"
                     filePattern="${LOG_HOME}/${FILE_NAME}-error-%d{yyyy-MM-dd}-%i.json.gz">
            <JsonTemplateLayout>
                <EventTemplateAdditionalField key="service" value="${APP_NAME}"/>
            </JsonTemplateLayout>
            <Filters>
                <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30">
                <Delete basePath="${LOG_HOME}" maxDepth="1">
                    <IfFileName glob="${FILE_NAME}-error-*.json.gz"/>
                    <IfLastModified age="30d"/>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!-- ==================== 异步包装（提升日志性能）==================== -->
        <!-- 全量日志使用异步，减少 I/O 对业务线程的阻塞 -->
        <Async name="AsyncAll" bufferSize="1024" includeLocation="false">
            <AppenderRef ref="JsonFileAll"/>
        </Async>
        <Async name="AsyncError" bufferSize="256" includeLocation="true">
            <AppenderRef ref="JsonFileError"/>
        </Async>

    </Appenders>

    <Loggers>

        <!-- Spring 框架日志：降低噪音 -->
        <Logger name="org.springframework" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncAll"/>
        </Logger>
        <Logger name="org.springframework.web" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncAll"/>
        </Logger>

        <!-- MyBatis Plus：生产关闭 SQL 日志（dev profile 通过 application-dev.yml 覆盖）-->
        <Logger name="com.baomidou.mybatisplus" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncAll"/>
        </Logger>
        <Logger name="org.apache.ibatis" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncAll"/>
        </Logger>

        <!-- Resilience4j 熔断日志 -->
        <Logger name="io.github.resilience4j" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncAll"/>
        </Logger>

        <!-- 爬虫模块：单独控制级别 -->
        <Logger name="com.resource.platform.crawler" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncAll"/>
            <AppenderRef ref="AsyncError"/>
        </Logger>

        <!-- 项目核心代码 -->
        <Logger name="com.resource.platform" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncAll"/>
            <AppenderRef ref="AsyncError"/>
        </Logger>

        <!-- 根 Logger -->
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncAll"/>
            <AppenderRef ref="AsyncError"/>
        </Root>

    </Loggers>

</Configuration>
